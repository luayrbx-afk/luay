local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TextService = game:GetService("TextService")

local Lib = { Elements = {}, Connections = {} }
local TInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad)

local Colors = {
    Main = Color3.fromRGB(251, 181, 84),
    White = Color3.fromRGB(255, 255, 255),
    Red = Color3.fromRGB(244, 67, 54),
    Beige = Color3.fromRGB(242, 218, 169),
    ScrollBG = Color3.fromRGB(210, 210, 210),
    InputBG = Color3.fromRGB(242, 203, 137),
    Green = Color3.fromRGB(144, 255, 107),
    Cyan = Color3.fromRGB(72, 224, 240)
}

function Lib:Window(title)
    local sg = Instance.new("ScreenGui", game:GetService("CoreGui") or game:GetService("Players").LocalPlayer.PlayerGui)
    sg.Name = "windowsv34"
    sg.ResetOnSpawn = false

    local main = Instance.new("Frame", sg)
    main.Size, main.Position = UDim2.new(0, 230, 0, 220), UDim2.new(0.5, -115, 0.5, -110)
    main.BackgroundColor3, main.BorderSizePixel = Colors.Main, 0

    local header = Instance.new("Frame", main)
    header.Size, header.BackgroundColor3, header.BorderSizePixel = UDim2.new(1, 0, 0, 24), Colors.Main, 0

    local tTitle = Instance.new("TextLabel", header)
    tTitle.Size, tTitle.Position = UDim2.new(1, -50, 1, 0), UDim2.new(0, 5, 0, 0)
    tTitle.BackgroundTransparency, tTitle.Text, tTitle.TextColor3 = 1, title, Colors.White
    tTitle.Font, tTitle.TextSize, tTitle.TextXAlignment = Enum.Font.SourceSansBold, 14, Enum.TextXAlignment.Left

    local btnCont = Instance.new("Frame", header)
    btnCont.Size, btnCont.Position, btnCont.BackgroundTransparency = UDim2.new(0, 48, 1, 0), UDim2.new(1, -48, 0, 0), 1

    local close = Instance.new("TextButton", btnCont)
    close.Size, close.Position, close.BackgroundColor3 = UDim2.new(0, 22, 0, 22), UDim2.new(0, 24, 0, 1), Colors.Red
    close.Text, close.TextColor3, close.BorderSizePixel = "X", Colors.White, 0

    local min = Instance.new("TextButton", btnCont)
    min.Size, min.Position, min.BackgroundColor3 = UDim2.new(0, 22, 0, 22), UDim2.new(0, 0, 0, 1), Colors.Beige
    min.Text, min.TextColor3, min.BorderSizePixel = "-", Colors.White, 0

    local body = Instance.new("Frame", main)
    body.Size, body.Position = UDim2.new(1, -6, 1, -30), UDim2.new(0, 3, 0, 27)
    body.BackgroundColor3, body.BorderSizePixel = Colors.White, 0
    body.ClipsDescendants = true

    local scroll = Instance.new("ScrollingFrame", body)
    scroll.Size, scroll.Position = UDim2.new(1, -18, 1, -4), UDim2.new(0, 2, 0, 2)
    scroll.BackgroundTransparency, scroll.BorderSizePixel, scroll.ScrollBarThickness = 1, 0, 0
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)

    local layout = Instance.new("UIListLayout", scroll)
    layout.Padding, layout.SortOrder = UDim.new(0, 4), Enum.SortOrder.LayoutOrder

    local sTrack = Instance.new("Frame", body)
    sTrack.Size, sTrack.Position = UDim2.new(0, 14, 1, -4), UDim2.new(1, -16, 0, 2)
    sTrack.BackgroundColor3, sTrack.BorderSizePixel = Colors.ScrollBG, 0

    local sUp = Instance.new("TextButton", sTrack)
    sUp.Size, sUp.BackgroundColor3, sUp.Text = UDim2.new(1, 0, 0, 14), Colors.Main, "^"
    sUp.BorderSizePixel, sUp.TextColor3, sUp.Font = 0, Colors.White, Enum.Font.SourceSansBold

    local sDown = Instance.new("TextButton", sTrack)
    sDown.Size, sDown.Position = UDim2.new(1, 0, 0, 14), UDim2.new(0, 0, 1, -14)
    sDown.BackgroundColor3, sDown.Text, sDown.BorderSizePixel = Colors.Main, "v", 0
    sDown.TextColor3, sDown.Font = Colors.White, Enum.Font.SourceSansBold

    local thumb = Instance.new("TextButton", sTrack)
    thumb.BackgroundColor3, thumb.BorderSizePixel, thumb.Text = Colors.Main, 0, ""

    -- Arrastar (PC/Mobile)
    local dragObj, dragStart, startPos
    header.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragObj = i dragStart = i.Position startPos = main.Position
            i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then dragObj = nil end end)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragObj and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            local delta = i.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Lógica Scroll
    local function UpdateScroll()
        local cSize = layout.AbsoluteContentSize.Y
        scroll.CanvasSize = UDim2.new(0, 0, 0, cSize)
        local ratio = math.clamp(scroll.AbsoluteWindowSize.Y / cSize, 0.15, 1)
        local trackH = sTrack.AbsoluteSize.Y - 28
        thumb.Size = UDim2.new(1, 0, 0, math.max(15, trackH * ratio))
        local scrollP = scroll.CanvasPosition.Y / math.max(1, cSize - scroll.AbsoluteWindowSize.Y)
        thumb.Position = UDim2.new(0, 0, 0, 14 + (scrollP * (trackH - thumb.Size.Y.Offset)))
        sTrack.Visible = ratio < 1
    end

    scroll:GetPropertyChangedSignal("CanvasPosition"):Connect(UpdateScroll)
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateScroll)

    local scrollingThumb = false
    thumb.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then scrollingThumb = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then scrollingThumb = false end end)
    
    RunService.RenderStepped:Connect(function()
        if scrollingThumb then
            local mY = (UserInputService:GetMouseLocation().Y - 36) - sTrack.AbsolutePosition.Y
            local trackH = sTrack.AbsoluteSize.Y - 28 - thumb.Size.Y.Offset
            local perc = math.clamp((mY - 14) / trackH, 0, 1)
            scroll.CanvasPosition = Vector2.new(0, perc * (scroll.CanvasSize.Y.Offset - scroll.AbsoluteWindowSize.Y))
        end
    end)

    sUp.MouseButton1Click:Connect(function() scroll.CanvasPosition -= Vector2.new(0, 30) end)
    sDown.MouseButton1Click:Connect(function() scroll.CanvasPosition += Vector2.new(0, 30) end)
    close.MouseButton1Click:Connect(function() sg:Destroy() end)
    
    local minState = false
    min.MouseButton1Click:Connect(function()
        minState = not minState
        TweenService:Create(main, TInfo, {Size = minState and UDim2.new(0, 230, 0, 24) or UDim2.new(0, 230, 0, 220)}):Play()
        body.Visible = not minState
    end)

    local function CreateBase(id, text)
        local f = Instance.new("Frame", scroll)
        f.Size, f.BackgroundColor3, f.BorderSizePixel = UDim2.new(1, 0, 0, 24), Colors.Main, 0
        local l = Instance.new("TextLabel", f)
        l.Size, l.Position = UDim2.new(1, -10, 1, 0), UDim2.new(0, 5, 0, 0)
        l.BackgroundTransparency, l.Text, l.TextColor3 = 1, text, Colors.White
        l.Font, l.TextSize, l.TextXAlignment = Enum.Font.SourceSansBold, 14, Enum.TextXAlignment.Left
        Lib.Elements[id] = { Frame = f, Label = l }
        return f
    end

    function Lib:Label(id, text)
        local f = Instance.new("Frame", scroll)
        f.BackgroundColor3, f.BorderSizePixel = Colors.Main, 0
        local l = Instance.new("TextLabel", f)
        l.Size, l.Position = UDim2.new(1, -10, 1, -4), UDim2.new(0, 5, 0, 2)
        l.BackgroundTransparency, l.Text, l.TextColor3 = 1, text, Colors.White
        l.Font, l.TextSize, l.TextXAlignment, l.TextWrapped = Enum.Font.SourceSansBold, 14, Enum.TextXAlignment.Left, true
        
        local function res()
            local ts = TextService:GetTextSize(l.Text, l.TextSize, l.Font, Vector2.new(scroll.AbsoluteSize.X - 25, 9999))
            f.Size = UDim2.new(1, 0, 0, ts.Y + 8)
            l.Size = UDim2.new(1, -10, 1, -4)
        end
        l:GetPropertyChangedSignal("Text"):Connect(res)
        res()
        Lib.Elements[id] = { Set = function(v) l.Text = v end }
    end

    function Lib:Toggle(id, text, def, cb)
        local f = CreateBase(id, text)
        local b = Instance.new("TextButton", f)
        b.Size, b.Position, b.BackgroundColor3, b.Text = UDim2.new(0, 36, 0, 14), UDim2.new(1, -40, 0.5, -7), Colors.InputBG, ""
        b.BorderSizePixel = 0
        local t = Instance.new("Frame", b)
        t.Size, t.BorderSizePixel = UDim2.new(0, 12, 0, 10), 0
        local state = def
        local function upd()
            TweenService:Create(t, TInfo, {Position = state and UDim2.new(1, -14, 0.5, -5) or UDim2.new(0, 2, 0.5, -5), BackgroundColor3 = state and Colors.Green or Colors.Red}):Play()
            cb(state)
        end
        b.MouseButton1Click:Connect(function() state = not state upd() end)
        Lib.Elements[id].Set = function(v) state = v upd() end
        upd()
    end

    function Lib:Button(id, text, cb)
        local f = CreateBase(id, text)
        local b = Instance.new("TextButton", f)
        b.Size, b.Position, b.BackgroundColor3, b.Text = UDim2.new(0, 36, 0, 14), UDim2.new(1, -40, 0.5, -7), Colors.InputBG, ""
        b.BorderSizePixel = 0
        local i = Instance.new("Frame", b)
        i.Size, i.Position, i.BackgroundColor3, i.BorderSizePixel = UDim2.new(0, 14, 0, 8), UDim2.new(0.5, -7, 0.5, -4), Colors.Cyan, 0
        b.MouseButton1Down:Connect(function() i.Size = UDim2.new(0, 12, 0, 6) i.Position = UDim2.new(0.5, -6, 0.5, -3) end)
        b.MouseButton1Up:Connect(function() i.Size = UDim2.new(0, 14, 0, 8) i.Position = UDim2.new(0.5, -7, 0.5, -4) cb() end)
    end

    function Lib:Slider(id, text, min, max, def, cb)
        local f = CreateBase(id, text)
        local s = Instance.new("TextButton", f)
        s.Size, s.Position, s.BackgroundColor3, s.Text = UDim2.new(0, 70, 0, 14), UDim2.new(1, -75, 0.5, -7), Colors.InputBG, ""
        s.BorderSizePixel = 0
        local fill = Instance.new("Frame", s)
        fill.Size, fill.BackgroundColor3, fill.BorderSizePixel = UDim2.new((def-min)/(max-min), 0, 1, 0), Colors.Cyan, 0
        local lV = Instance.new("TextLabel", s)
        lV.Size, lV.BackgroundTransparency, lV.Text, lV.TextColor3 = UDim2.new(1, 0, 1, 0), 1, tostring(def), Colors.White
        lV.Font, lV.TextSize = Enum.Font.SourceSansBold, 11
        
        local function move()
            local p = math.clamp((UserInputService:GetMouseLocation().X - s.AbsolutePosition.X) / s.AbsoluteSize.X, 0, 1)
            local val = math.floor(min + (max-min)*p)
            fill.Size = UDim2.new(p, 0, 1, 0)
            lV.Text = tostring(val)
            cb(val)
        end
        local active = false
        s.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then active = true move() end end)
        UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then active = false end end)
        UserInputService.InputChanged:Connect(function(i) if active and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then move() end end)
    end

    function Lib:Textbox(id, text, cb)
        local f = CreateBase(id, text)
        local b = Instance.new("TextBox", f)
        b.Size, b.Position, b.BackgroundColor3 = UDim2.new(0, 70, 0, 16), UDim2.new(1, -75, 0.5, -8), Colors.InputBG
        b.BorderSizePixel, b.Text, b.TextColor3, b.Font, b.TextSize = 0, "", Colors.White, Enum.Font.SourceSansBold, 12
        b.FocusLost:Connect(function() cb(b.Text) end)
    end

    function Lib:Dropdown(id, text, multi, options, cb)
        local f = CreateBase(id, text)
        local b = Instance.new("TextButton", f)
        b.Size, b.Position, b.BackgroundColor3 = UDim2.new(0, 70, 0, 16), UDim2.new(1, -75, 0.5, -8), Colors.InputBG
        b.Text, b.TextColor3, b.Font, b.TextSize, b.BorderSizePixel = "Select", Colors.White, Enum.Font.SourceSansBold, 12, 0
        
        local dF = Instance.new("Frame", scroll)
        dF.Size, dF.BackgroundColor3, dF.BorderSizePixel, dF.Visible = UDim2.new(1, 0, 0, 0), Colors.InputBG, 0, false
        dF.AutomaticSize = Enum.AutomaticSize.Y
        Instance.new("UIListLayout", dF)

        local selected = {}
        b.MouseButton1Click:Connect(function() dF.Visible = not dF.Visible end)

        for _, opt in pairs(options) do
            local o = Instance.new("TextButton", dF)
            o.Size, o.BackgroundColor3, o.BorderSizePixel = UDim2.new(1, 0, 0, 20), Colors.InputBG, 0
            o.Text, o.TextColor3, o.Font, o.TextSize, o.TextXAlignment = "  "..opt.Name, Colors.White, Enum.Font.SourceSans, 12, Enum.TextXAlignment.Left
            if opt.Image then
                local img = Instance.new("ImageLabel", o)
                img.Size, img.Position, img.Image, img.BackgroundTransparency = UDim2.new(0,14,0,14), UDim2.new(1,-18,0.5,-7), opt.Image, 1
            end
            o.MouseButton1Click:Connect(function()
                if multi then
                    if selected[opt.Name] then selected[opt.Name] = nil o.TextColor3 = Colors.White else selected[opt.Name] = true o.TextColor3 = Colors.Green end
                    local list = {} for k in pairs(selected) do table.insert(list, k) end
                    b.Text = #list > 0 and table.concat(list, ", "):sub(1,10)..".." or "Select"
                    cb(list)
                else
                    b.Text = opt.Name dF.Visible = false cb(opt.Name)
                end
            end)
        end
    end

    return Lib
end

return Lib
